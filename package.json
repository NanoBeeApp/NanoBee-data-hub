{
	"name": "init-hono-tanstack-rpc",
	"description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
	"scripts": {
		"build": "vite build",
		"cf-typegen": "wrangler types",
		"check": "vite build && wrangler deploy --dry-run",
		"deploy:prod": "vite build --mode prod && wrangler deploy --env prod",
		"deploy:dev": "vite build --mode dev && wrangler deploy --env dev",
		"deploy": "pnpm deploy:prod && pnpm deploy:dev",
		"dev": "vite",
		"start:remote": "wrangler dev --remote",
		"lint": "eslint .",
		"preview": "npm run build && vite preview",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run"
	},
	"cloudflare": {
		"label": "Vite React Template",
