# Environment variable template
# Copy to .env for local development
# All VITE_* variables are baked into the JS bundle at build time and readable by both the browser and SSR
# Server-only variables belong in env.prod.vars / env.dev.vars inside wrangler.json

VITE_AUTH_ISSUER=https://pro.windseed.app
VITE_AUTH_CLIENT_ID=
VITE_AUTH_CLIENT_SECRET=
VITE_AUTH_REDIRECT_URI=http://localhost:5173/oauth/callback
VITE_GOOGLE_CLIENT_ID=
VITE_SESSION_SECRET=
