# 环境变量模板
# 复制为 .env 用于本地开发
# 所有 VITE_* 变量构建时 bake 进 JS bundle，浏览器和 SSR 都可读
# 纯服务端变量放在 wrangler.json 的 env.prod.vars / env.dev.vars 中

VITE_AUTH_ISSUER=https://pro.windseed.app
VITE_AUTH_CLIENT_ID=
VITE_AUTH_CLIENT_SECRET=
VITE_AUTH_REDIRECT_URI=http://localhost:5173/oauth/callback
VITE_GOOGLE_CLIENT_ID=
VITE_SESSION_SECRET=
